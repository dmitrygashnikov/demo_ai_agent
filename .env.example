# ==========================================================================
# Adaptive AI Coding Tutor — environment template
# Copy this file to ".env" and fill in the values, then run: docker compose up
# ==========================================================================

# --------------------------------------------------------------------------
# LLM provider (OpenAI-compatible protocol)
# Works with OpenAI, OpenRouter, Together, local vLLM/Ollama, etc.
# --------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
# Vector dimension of the embedding model above (text-embedding-3-small = 1536)
EMBEDDING_DIM=1536

# --------------------------------------------------------------------------
# Optional: RapidAPI CodeRunner.
# If BOTH variables below are set, code execution goes ONLINE through RapidAPI.
# If left empty, code runs in the local "code-executor" container.
# --------------------------------------------------------------------------
RAPIDAPI_KEY=
RAPIDAPI_CODERUNNER_HOST=

# --------------------------------------------------------------------------
# PostgreSQL (profile, progress, task-serve history, LangGraph checkpointer)
# --------------------------------------------------------------------------
POSTGRES_USER=tutor
POSTGRES_PASSWORD=tutor_pass
POSTGRES_DB=tutor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --------------------------------------------------------------------------
# Qdrant (vector DB for RAG content)
# --------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=tutor_content

# --------------------------------------------------------------------------
# Redis (sessions, sandbox queue, rate limiting)
# --------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --------------------------------------------------------------------------
# Local code-executor service (used when RapidAPI is not configured)
# --------------------------------------------------------------------------
CODE_EXECUTOR_URL=http://code-executor:9000
# Hard limits for student/agent code execution in the sandbox
EXECUTION_TIMEOUT_SECONDS=10
EXECUTION_MEMORY_MB=256

# --------------------------------------------------------------------------
# Web search (SearXNG via SearXNG MCP server) — used for remediation links and
# grounding internet-sourced task generation. Fully OPTIONAL and fail-open:
# if these services are down the tutor still works (no links / curated tasks).
# --------------------------------------------------------------------------
SEARXNG_URL=http://searxng:8080
SEARXNG_MCP_URL=http://searxng-mcp:8077
SEARXNG_MCP_PORT=8077
SEARXNG_SECRET=changeme-searxng-secret
# Master switch for live LLM task generation (sandbox-verified). When false the
# tutor serves only curated tasks (exactly today's behaviour).
INTERNET_TASKS_ENABLED=true

# --------------------------------------------------------------------------
# Adaptive tutor behaviour
# --------------------------------------------------------------------------
# A task may not be served to a student more than once per this many solves.
COOLDOWN_SOLVES=500
# Max code self-execution regeneration attempts before giving up.
MAX_REGEN_ATTEMPTS=3
# Consecutive successes required to mark a skill as mastered.
MASTERY_SUCCESS_STREAK=2
# Consecutive successes on a mastered skill that trigger real-world cases.
ADVANCED_SUCCESS_STREAK=3

# --------------------------------------------------------------------------
# Guardrails
# --------------------------------------------------------------------------
# On-topic guardrail: when true, off-topic chat (not about programming or the
# current learning process) is politely declined. Fail-open if the LLM
# classifier is unavailable. This is also runtime-editable via the Graph
# Settings UI / PUT /api/graph/settings (applied WITHOUT a restart); this value
# only seeds the initial default.
TOPIC_GUARD_ENABLED=true

# --------------------------------------------------------------------------
# Langfuse observability (LangGraph tracing) — ENABLED OUT OF THE BOX
# Tracing works by default: docker-compose auto-provisions a Langfuse org,
# project, default admin user and API keys, and passes the SAME keys to the
# backend. Leave the two keys below EMPTY to use the built-in compose defaults
# (pk-lf-tutor-public-key / sk-lf-tutor-secret-key); or set your own here to
# override both the provisioned project keys and the backend keys.
# To DISABLE tracing entirely, set LANGFUSE_INIT_PROJECT_*/LANGFUSE_*_KEY such
# that the backend keys are empty.
# --------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Inside the compose network the backend reaches Langfuse at http://langfuse:3000
LANGFUSE_HOST=http://langfuse:3000
# Langfuse self-hosted dedicated Postgres + app secrets (used by docker compose).
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse_pass
LANGFUSE_DB_NAME=langfuse
LANGFUSE_NEXTAUTH_SECRET=changeme-nextauth-secret
LANGFUSE_SALT=changeme-salt
LANGFUSE_NEXTAUTH_URL=http://localhost:3001

# Default Langfuse admin account + project, auto-created on first boot.
# You CAN OVERRIDE the admin login/password here. Out of the box you can log in
# to the Langfuse UI (http://localhost:3001) with:
#   email:    admin@example.com   (LANGFUSE_INIT_USER_EMAIL)
#   password: qwerty123456        (LANGFUSE_INIT_USER_PASSWORD)
# The username/name shown in Langfuse is "admin" (LANGFUSE_INIT_USER_NAME).
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=qwerty123456
LANGFUSE_INIT_ORG_ID=tutor-org
LANGFUSE_INIT_PROJECT_ID=tutor-project

# --------------------------------------------------------------------------
# Application authentication (JWT) — SEPARATE from the Langfuse admin account
# --------------------------------------------------------------------------
# Secret used to SIGN application JWTs. A dev default exists in code so the
# stack runs out-of-the-box; CHANGE THIS IN PRODUCTION to a long random value.
JWT_SECRET=dev-insecure-change-me-in-production
# Access-token lifetime in minutes (default 7 days).
JWT_EXPIRE_MINUTES=10080

# --------------------------------------------------------------------------
# Default APPLICATION user — seeded at backend startup.
# This is the login for the tutor app itself (NOT Langfuse). It is created with
# an initialised learning profile, which also guarantees a valid users row
# exists (so skill_progress foreign keys never dangle). Override as needed.
#   email:    admin@example.com   password: qwerty123456   name: admin
# --------------------------------------------------------------------------
APP_DEFAULT_USER_EMAIL=admin@example.com
APP_DEFAULT_USER_PASSWORD=qwerty123456
APP_DEFAULT_USER_NAME=admin
# Starting language for the default user's seeded profile (python|javascript).
APP_DEFAULT_USER_LANGUAGE=python

# --------------------------------------------------------------------------
# App
# --------------------------------------------------------------------------
SEED_ON_STARTUP=true
LOG_LEVEL=INFO
