# ==========================================================================
# Adaptive AI Coding Tutor — environment template
# Copy this file to ".env" and fill in the values, then run: docker compose up
# ==========================================================================

# --------------------------------------------------------------------------
# LLM provider (OpenAI-compatible protocol)
# Works with OpenAI, OpenRouter, Together, local vLLM/Ollama, etc.
# --------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
# Vector dimension of the embedding model above (text-embedding-3-small = 1536)
EMBEDDING_DIM=1536

# --------------------------------------------------------------------------
# Optional: RapidAPI CodeRunner.
# If BOTH variables below are set, code execution goes ONLINE through RapidAPI.
# If left empty, code runs in the local "code-executor" container.
# --------------------------------------------------------------------------
RAPIDAPI_KEY=
RAPIDAPI_CODERUNNER_HOST=

# --------------------------------------------------------------------------
# PostgreSQL (profile, progress, task-serve history, LangGraph checkpointer)
# --------------------------------------------------------------------------
POSTGRES_USER=tutor
POSTGRES_PASSWORD=tutor_pass
POSTGRES_DB=tutor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --------------------------------------------------------------------------
# Qdrant (vector DB for RAG content)
# --------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=tutor_content

# --------------------------------------------------------------------------
# Redis (sessions, sandbox queue, rate limiting)
# --------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --------------------------------------------------------------------------
# Local code-executor service (used when RapidAPI is not configured)
# --------------------------------------------------------------------------
CODE_EXECUTOR_URL=http://code-executor:9000
# Hard limits for student/agent code execution in the sandbox
EXECUTION_TIMEOUT_SECONDS=10
EXECUTION_MEMORY_MB=256

# --------------------------------------------------------------------------
# Adaptive tutor behaviour
# --------------------------------------------------------------------------
# A task may not be served to a student more than once per this many solves.
COOLDOWN_SOLVES=500
# Max code self-execution regeneration attempts before giving up.
MAX_REGEN_ATTEMPTS=3
# Consecutive successes required to mark a skill as mastered.
MASTERY_SUCCESS_STREAK=2
# Consecutive successes on a mastered skill that trigger real-world cases.
ADVANCED_SUCCESS_STREAK=3

# --------------------------------------------------------------------------
# Langfuse observability (OPTIONAL — LangGraph tracing)
# Tracing is fully optional. Leave the keys EMPTY to disable it entirely; the
# backend runs normally without Langfuse. To enable: open the Langfuse UI
# (http://localhost:3001), create a project, copy its public/secret keys here
# (or pre-set them via the LANGFUSE_INIT_* compose vars) and restart the backend.
# --------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Inside the compose network the backend reaches Langfuse at http://langfuse:3000
LANGFUSE_HOST=http://langfuse:3000
# Langfuse self-hosted dedicated Postgres + app secrets (used by docker compose).
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse_pass
LANGFUSE_DB_NAME=langfuse
LANGFUSE_NEXTAUTH_SECRET=changeme-nextauth-secret
LANGFUSE_SALT=changeme-salt
LANGFUSE_NEXTAUTH_URL=http://localhost:3001

# --------------------------------------------------------------------------
# App
# --------------------------------------------------------------------------
SEED_ON_STARTUP=true
LOG_LEVEL=INFO
