# ---------------------------------------------------------------------------
# Secrets / environment
# ---------------------------------------------------------------------------
.env
.env.*
*.env.local
# Keep the template committed
!.env.example

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / type-check / lint / coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ---------------------------------------------------------------------------
# Node / Frontend (Vite / React)
# ---------------------------------------------------------------------------
node_modules/
frontend/node_modules/
frontend/dist/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Keep the lockfile committed for reproducible `npm ci` builds
!frontend/package-lock.json

# ---------------------------------------------------------------------------
# Docker / runtime data
# ---------------------------------------------------------------------------
# Named volumes (pgdata, qdrantdata) live inside Docker, not the repo.
# Ignore any local bind-mount data dirs or sandbox/runtime artifacts if created.
data/
*.pid

# ---------------------------------------------------------------------------
# Logs / temporary
# ---------------------------------------------------------------------------
*.log
logs/
tmp/
*.tmp

# ---------------------------------------------------------------------------
# IDE / OS
# ---------------------------------------------------------------------------
.idea/
.vscode/
.DS_Store
Thumbs.db
